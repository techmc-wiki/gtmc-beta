# Database
DATABASE_URL=
# Direct (non-pooled) connection for Prisma migrations (port 5432 on Supabase)
DIRECT_URL=

# Public site origin used for canonical URLs, sitemap, OpenGraph, and JSON-LD.
# Falls back to http://localhost:3000 when unset. Must include scheme, no trailing slash.
NEXT_PUBLIC_APP_URL=

# GitHub (required for feature issues and file storage)
GITHUB_FEATURES_ISSUES_PAT=
GITHUB_FEATURES_WRITE_PAT=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Vercel Blob (required for large file uploads >=4.5MB)
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_HOSTNAME=

# Glossary submodule integration (optional; defaults to TechMC-Glossary/TechMC-Glossary)
GITHUB_GLOSSARY_REPO_OWNER=TechMC-Glossary
GITHUB_GLOSSARY_REPO_NAME=TechMC-Glossary
# PAT for opening glossary PRs. Required scopes (fine-grained PAT):
#   - Contents: Read and write
#   - Pull requests: Read and write
GITHUB_GLOSSARY_WRITE_PAT=
