{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "suspicious": "warn"
  },
  "env": {
    "browser": true,
    "builtin": true,
    "es2024": true,
    "node": true
  },
  "ignorePatterns": [
    ".next/**",
    ".vercel/**",
    "out/**",
    "build/**",
    "next-env.d.ts",
    ".worktrees/**",
    ".sisyphus/**",
    ".agents/**",
    ".claude/**",
    "articles/**",
    "**/*.cjs"
  ],
  "plugins": [
    "typescript",
    "react",
    "nextjs",
    "react",
    "react-perf",
    "jsx-a11y",
    "oxc",
    "eslint",
    "import",
    "unicorn"
  ],
  "rules": {
    "no-control-regex": "off",
    "react/react-in-jsx-scope": "off",
    "react-perf/jsx-no-new-function-as-prop": "off",
    "typescript/no-unused-vars": [
      "warn",
      {
        "ignoreRestSiblings": true
      }
    ]
  },
  "settings": {
    "next": {
      "rootDir": "."
    },
    "react": {
      "version": "19.2.6"
    }
  }
}
